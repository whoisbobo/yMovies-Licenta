// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String          @id @default(uuid())
  email     String          @unique
  username  String          @unique
  avatarUrl String?
  role      Role            @default(USER) 
  createdAt DateTime        @default(now())
  reviews   Review[]
  watchlist WatchlistItem[]
}

model WatchlistItem {
  id        String   @id @default(uuid())
  userId    String
  movieId   Int
  mediaType String   @default("movie")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId, mediaType], references: [id, mediaType], onDelete: Cascade)

  @@unique([userId, movieId, mediaType])
}

model Movie {
  id          Int
  mediaType   String
  title       String
  description String?
  releaseDate DateTime?
  posterUrl   String?
  
  categoryId  Int
  category    Category        @relation(fields: [categoryId], references: [id])
  reviews     Review[]
  watchlist   WatchlistItem[]

  // Cheia primară compusă
  @@id([id, mediaType])
}

model Category {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  movies Movie[]
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int      
  comment   String?
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  movieId   Int
  mediaType String   @default("movie")
  movie     Movie    @relation(fields: [movieId, mediaType], references: [id, mediaType])

  @@unique([userId, movieId, mediaType]) 
}